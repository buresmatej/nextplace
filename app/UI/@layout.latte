<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width">

	<title>{ifset title}{include title|stripHtml} | {/ifset}Nextplace</title>
	<link rel="stylesheet" href={="/css/style.css"}>
	{asset? 'main.js'}
</head>

<body>
	<div n:foreach="$flashes as $flash" n:class="flash, $flash->type">{$flash->message}</div>
	<header class="navbar">
		<a n:href="Home:default" class="home-btn">
			<div class="logo">
				<svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"></polygon></svg>
				Nextplace
			</div>
		</a>
		<div class="nav-links">
			{if !$user->isLoggedIn()}
				<a n:href="Sign:login" class="nav-link">Log in</a>
				<a n:href="Sign:register" class="nav-btn">Sign up</a>
			{else}
				<a n:href="DestinationLog:datagrid" class="nav-link">Destination log</a>
				<a n:href="Ai:recommendation" class="nav-link">Recommendations</a>
				<a n:href="User:stats" class="nav-link">Stats</a>


				<a n:href="Sign:out" class="logout-btn">
					<span>Log out</span>
					<svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
						<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
						<polyline points="16 17 21 12 16 7"></polyline>
						<line x1="21" y1="12" x2="9" y2="12"></line>
					</svg>
				</a>
			{/if}
		</div>
	</header>
	{include content}
</body>
</html>
